DATABASE_URL=postgresql://user:pass@localhost:5432/moneyflow
JWT_SECRET=change_this_in_production
JWT_REFRESH_SECRET=change_this_in_production
REDIS_URL=redis://localhost:6379
PORT=3000
NODE_ENV=production
TWILIO_ACCOUNT_SID=optional
TWILIO_AUTH_TOKEN=optional
TWILIO_WHATSAPP_FROM=optional

# Must match your Postgres user/password.
#
# P1000 "Authentication failed" (Nest exits on startup unless DATABASE_DISABLED=true):
#   (1) Copy this file to .env and set DATABASE_URL, e.g.
#       Local Postgres on default port (example password "root"):
#         postgresql://postgres:root@localhost:5432/moneyflow
#         postgresql://postgres:YOUR_PASSWORD@localhost:5432/moneyflow
#       Postgres from docker-compose (host port 5433):
#         postgresql://postgres:postgres@localhost:5433/moneyflow
#   (2) Create DB if needed (psql / pgAdmin): CREATE DATABASE moneyflow;
#   (3) URL-encode special characters in the password (e.g. @ → %40).
#
# Temporary: API up without Postgres (no real login/data):
#   DATABASE_DISABLED=true
#   REDIS_DISABLED=true
DATABASE_URL="postgresql://user:pass@localhost:5432/moneyflow"

# Set true to skip connecting to Postgres at startup (API still listens; auth/data routes need a real DB).
# Use with REDIS_DISABLED=true when you only want the server up, e.g. to verify Flutter can reach :4000.
DATABASE_DISABLED=false

REDIS_URL="redis://localhost:6379"

# Set true to skip Redis when it is not installed (notifications/recurring run without BullMQ workers)
REDIS_DISABLED=false

JWT_SECRET=change_this_in_production
JWT_REFRESH_SECRET=change_this_in_production
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_DAYS=7

# Optional: HMAC secret for refresh token hashes at rest (recommended in production).
# When set, new refresh tokens use HMAC-SHA256(pepper, token); existing DB rows still verify via legacy SHA-256 until rotated.
REFRESH_TOKEN_PEPPER=

# AES-256-GCM for sensitive columns (e.g. insurance policy numbers). Use 64 hex chars, or base64 of 32 raw bytes.
# If unset, those fields stay plaintext and a warning is logged at startup.
FIELD_ENCRYPTION_KEY=

# Behind nginx/ingress: trust X-Forwarded-For for req.ip (rate limits / session IP hashing). Set to 0 to disable.
TRUST_PROXY=1

# Multi-user workspaces: optional header to select shared ledger (default = your primary workspace).
# X-Workspace-Id: <workspace cuid from GET /api/workspaces>

# Optional: AI chat + insight polish — Groq / Gemini / OpenAI with fallback
# Fallback order (comma-separated): groq,gemini,openai
AI_PROVIDER_ORDER=groq,gemini,openai

# Groq (OpenAI-compatible API)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Gemini (Google): Generative Language API key from Google AI Studio
GEMINI_API_KEY=
# Same as GEMINI_API_KEY; supported for Render env naming
gemini_api=
GEMINI_MODEL=gemini-1.5-flash
# OpenAI (used if no Gemini key)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

DJANGO_SOURCE_DB_PATH=../backend/db.sqlite3

# --- WhatsApp (Twilio WhatsApp or Meta Cloud API) ---
# Master switch for outbound sends (digests, alerts, OTP, replies).
WHATSAPP_ENABLED=true
# Scheduled digests (requires Redis for queued sends, or sends inline if REDIS_DISABLED=true).
WHATSAPP_DIGESTS_ENABLED=true
# Twilio WhatsApp (https://console.twilio.com/)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# E.g. whatsapp:+14155238886 (sandbox) or your approved sender
TWILIO_WHATSAPP_FROM=
# Public origin + global API prefix, no trailing slash. Used for webhook signature checks.
# Example: https://api.yourdomain.com/api
PUBLIC_WEBHOOK_BASE_URL=
# Production: set false. Dev/staging: true skips Twilio X-Twilio-Signature validation.
WHATSAPP_WEBHOOK_SKIP_VERIFY=true
# Meta Cloud API (optional): GET /api/whatsapp/webhook/meta verification
META_WHATSAPP_VERIFY_TOKEN=

